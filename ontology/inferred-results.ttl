cap:EndEffector a owl:Class ;
    rdfs:label "end effector"@en ;
    rdfs:comment "A robot component used to physically interact with objects, such as a gripper."@en ;
    rdfs:subClassOf owl:Thing,
        cap:EndEffector ;
    owl:equivalentClass cap:EndEffector ;
    owl:sameAs cap:EndEffector ;
    skos:definition "A robot component used to physically interact with objects, such as a gripper."@en ;
    skos:prefLabel "end effector"@en ;
    skos:relatedMatch soma:Gripper ;
    skos:scopeNote "This homework treats end effectors at a simplified level sufficient for graspability reasoning."@en .

cap:StackabilityAffordance a owl:Class ;
    rdfs:label "stackability affordance"@en ;
    rdfs:comment "An affordance by which an object can participate in a stacking relation with another object."@en ;
    rdfs:subClassOf owl:Thing,
        cap:Affordance,
        cap:StackabilityAffordance ;
    owl:equivalentClass cap:StackabilityAffordance ;
    owl:sameAs cap:StackabilityAffordance .

cap:SupportAffordance a owl:Class ;
    rdfs:label "support affordance"@en ;
    rdfs:comment "An affordance by which an object can support the placement or arrangement of other objects."@en ;
    rdfs:subClassOf owl:Thing,
        cap:Affordance,
        cap:SupportAffordance ;
    owl:equivalentClass cap:SupportAffordance ;
    owl:sameAs cap:SupportAffordance .

