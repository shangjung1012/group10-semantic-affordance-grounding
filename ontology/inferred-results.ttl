g10:blueCup01 a _:cb1515ae51dc725343774ea3c94f7c0d42e6f1c0728a14142c1c69d8fa3eee252773,
        _:cb15ea21b01698b15a662ee322c107a89fe9f35c7a62cad94bad441360adda38d2a8,
