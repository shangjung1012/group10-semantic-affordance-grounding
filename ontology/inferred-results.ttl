xsd:decimal a rdfs:Datatype ;
    owl:sameAs xsd:decimal .

cap:ManipulationTask a owl:Class ;
    rdfs:label "manipulation task"@en ;
    rdfs:comment "A task in which a robot changes the pose, state, or arrangement of physical objects."@en ;
    rdfs:subClassOf owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    owl:equivalentClass cap:ManipulationTask ;
    owl:sameAs cap:ManipulationTask ;
    skos:broadMatch dul:Task ;
    skos:definition "A robot task in which an agent changes the pose, state, or arrangement of physical objects."@en ;
    skos:prefLabel "manipulation task"@en ;
    skos:relatedMatch soma:Manipulating ;
    skos:scopeNote "The course term covers the project tasks, including cup stacking, cutlery arrangement, and toy block collection."@en .

g10:graspingAffordance a owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    rdfs:label "grasping affordance"@en ;
    rdfs:comment "A reusable Group 10 affordance individual indicating that an object can be grasped by the robot gripper."@en ;
    owl:sameAs g10:graspingAffordance .

g10:robotGripper a owl:Thing,
        cap:EndEffector ;
    rdfs:label "robot gripper"@en ;
    rdfs:comment "The simplified gripper end effector used by Group 10 for graspability reasoning."@en ;
    owl:sameAs g10:robotGripper .

owl:Restriction owl:sameAs owl:Restriction .

owl:AnnotationProperty owl:sameAs owl:AnnotationProperty .

cap:GraspingAffordance a owl:Class ;
    rdfs:label "grasping affordance"@en ;
    rdfs:comment "An affordance by which an object may be grasped, held, lifted, or repositioned by a robot gripper."@en ;
    rdfs:subClassOf owl:Thing,
        cap:Affordance,
        cap:GraspingAffordance ;
    owl:equivalentClass cap:GraspingAffordance ;
    owl:sameAs cap:GraspingAffordance ;
    skos:definition "An affordance by which an object can be grasped, held, lifted, or repositioned by a robot gripper."@en ;
    skos:prefLabel "grasping affordance"@en ;
    skos:relatedMatch soma:Disposition,
        soma:Grasping ;
    skos:scopeNote "The course term is represented locally as an affordance class. SOMA models affordance-like knowledge through dispositions and task-oriented action descriptions; therefore relatedMatch is used rather than exactMatch."@en .

cap:Task a owl:Class ;
    rdfs:label "task"@en ;
    rdfs:comment "A goal-directed activity to be performed or evaluated in the course project."@en ;
    rdfs:subClassOf owl:Thing,
        cap:Task ;
    owl:equivalentClass cap:Task ;
    owl:sameAs cap:Task .

