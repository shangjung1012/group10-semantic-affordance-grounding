<https://hcis.io/ontology/aicapstone/2026> a owl:Ontology ;
    rdfs:label "AI Capstone 2026 Course Ontology"@en ;
    dcterms:created "2026-05-22"^^xsd:date ;
    dcterms:creator cap:ccyont ;
    dcterms:description "This ontology defines a compact course vocabulary for representing physical task objects, task roles, manipulation affordances, grounding identifiers, and inferable graspability in the AI Capstone 2026 Physical AI project."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "AI Capstone 2026 Course Ontology"@en ;
    vann:preferredNamespacePrefix "cap" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/" ;
    rdfs:comment "A reduced educational ontology profile for semantic and affordance grounding of graspable objects in the AI Capstone 2026 course project."@en ;
    owl:sameAs <https://hcis.io/ontology/aicapstone/2026> .

cap:group10 a owl:Ontology ;
    rdfs:label "Group 10 Semantic Affordance Grounding Ontology"@en ;
    dcterms:created "2026-05-26"^^xsd:date ;
    dcterms:creator g10:group10 ;
    dcterms:description "This ontology defines Group 10 object instances, task roles, affordance individuals, and the graspable-object reasoning axiom used for Homework 5."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "Group 10 Semantic Affordance Grounding Ontology"@en ;
    vann:preferredNamespacePrefix "g10" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/group10/" ;
    rdfs:comment "Group 10 ontology for grounding baseline AI Capstone task objects and inferring graspable objects from grasping affordances."@en ;
    owl:imports <file:///home/shangjung/Documents/group10-semantic-affordance-grounding/ontology/imports/course-affordance.ttl> ;
    owl:sameAs cap:group10 .

g10:cupStackingTask a owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    rdfs:label "cup stacking task"@en ;
    rdfs:comment "The baseline task in which the blue and pink cups are manipulation targets."@en ;
    owl:sameAs g10:cupStackingTask ;
    cap:hasTargetObject g10:blueCup01,
        g10:pinkCup01 .

g10:cutleryArrangementTask a owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    rdfs:label "cutlery arrangement task"@en ;
    rdfs:comment "The baseline task in which the knife and fork are arranged with respect to the plate."@en ;
    owl:sameAs g10:cutleryArrangementTask ;
    cap:hasReferenceObject g10:plate01 ;
    cap:hasTargetObject g10:fork01,
        g10:knife01 .

g10:toyBlockCollectionTask a owl:Thing,
        cap:ManipulationTask,
        cap:Task ;
    rdfs:label "toy block collection task"@en ;
    rdfs:comment "The baseline task in which toy blocks are collected into the basket."@en ;
    owl:sameAs g10:toyBlockCollectionTask ;
    cap:hasReferenceObject g10:basket01 ;
    cap:hasTargetObject g10:block01,
        g10:block02 .

<file:///home/shangjung/Documents/group10-semantic-affordance-grounding/ontology/imports/course-affordance.ttl> owl:sameAs <file:///home/shangjung/Documents/group10-semantic-affordance-grounding/ontology/imports/course-affordance.ttl> .

