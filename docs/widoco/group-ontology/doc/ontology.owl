    <!-- https://hcis.io/ontology/aicapstone/2026/GraspableObject -->


    <owl:Class rdf:about="https://hcis.io/ontology/aicapstone/2026/GraspableObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://hcis.io/ontology/aicapstone/2026/hasAffordance"/>
                        <owl:someValuesFrom rdf:resource="https://hcis.io/ontology/aicapstone/2026/GraspingAffordance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://hcis.io/ontology/aicapstone/2026/PhysicalObject"/>
        <rdfs:comment xml:lang="en">A physical object inferred to afford grasping by the robot gripper in the task context.</rdfs:comment>
        <rdfs:label xml:lang="en">graspable object</rdfs:label>
    </owl:Class>
    


