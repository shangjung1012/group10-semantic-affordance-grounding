#    Classes
#################################################################

###  http://xmlns.com/foaf/0.1/Group
<http://xmlns.com/foaf/0.1/Group> rdf:type owl:Class .


###  https://hcis.io/ontology/aicapstone/2026/GraspableObject
<https://hcis.io/ontology/aicapstone/2026/GraspableObject> rdf:type owl:Class ;
                                                           owl:equivalentClass [ owl:intersectionOf ( <https://hcis.io/ontology/aicapstone/2026/PhysicalObject>
                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                                                        owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                                                                      ]
                                                                                                    ) ;
                                                                                 rdf:type owl:Class
                                                                               ] ;
                                                           rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                           rdfs:comment "A physical object inferred to afford grasping by the robot gripper in the task context."@en ;
                                                           rdfs:label "graspable object"@en .


